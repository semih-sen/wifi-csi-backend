{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "CsiRadar.Backend": "Debug"
    }
  },

  "Mqtt": {
    "BrokerHost": "localhost",
    "BrokerPort": 1883,
    "CsiTopic": "sensor/csi/raw",
    "AutomationTopic": "home/radar/automation",
    "StatusTopic": "home/radar/status",
    "ClientId": "CsiRadar-Backend",
    "ConnectionTimeoutSeconds": 30,
    "ReconnectDelaySeconds": 5
  },

  "Processing": {
    "WindowSize": 100,
    "SlideStep": 50,
    "LowPassCutoffHz": 20.0,
    "SamplingRateHz": 100.0,
    "FilterOrder": 4
  },

  "Inference": {
    "ModelPath": "Models/csi_activity_model.onnx",
    "ConfidenceThreshold": 0.7,
    "ConsecutiveCountForAutomation": 3
  }
}
